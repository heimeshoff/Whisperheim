<Window x:Class="WhisperHeim.Views.TranscriptionProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Whisperheim — Transcribing Call"
        Width="520" Height="320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Transcribing Call Recording"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <!-- Stage description -->
        <TextBlock Grid.Row="2"
                   x:Name="StageText"
                   Text="Preparing..."
                   FontSize="13"
                   TextWrapping="Wrap"
                   Opacity="0.8" />

        <!-- Detail text -->
        <TextBlock Grid.Row="4"
                   x:Name="DetailText"
                   Text=""
                   FontSize="11"
                   Opacity="0.5" />

        <!-- Stage label -->
        <TextBlock Grid.Row="6"
                   Text="Stage Progress"
                   FontSize="11"
                   Opacity="0.6" />

        <!-- Stage progress bar -->
        <ProgressBar Grid.Row="8"
                     x:Name="StageProgress"
                     Height="16"
                     Minimum="0"
                     Maximum="100"
                     Value="0" />

        <!-- Overall label -->
        <TextBlock Grid.Row="10"
                   Text="Overall Progress"
                   FontSize="11"
                   Opacity="0.6" />

        <!-- Overall progress bar -->
        <ProgressBar Grid.Row="12"
                     x:Name="OverallProgress"
                     Height="20"
                     Minimum="0"
                     Maximum="100"
                     Value="0" />

        <!-- Cancel button -->
        <Button Grid.Row="14"
                x:Name="CancelButton"
                Content="Cancel"
                Width="100"
                HorizontalAlignment="Right"
                Click="CancelButton_Click" />
    </Grid>
</Window>
