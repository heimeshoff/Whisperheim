<Window x:Class="WhisperHeim.Views.ModelDownloadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Whisperheim — Downloading Models"
        Width="520" Height="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Downloading AI Models"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <!-- Status text -->
        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Text="Preparing download..."
                   FontSize="13"
                   TextWrapping="Wrap"
                   Opacity="0.8" />

        <!-- File detail text -->
        <TextBlock Grid.Row="4"
                   x:Name="FileDetailText"
                   Text=""
                   FontSize="11"
                   Opacity="0.5" />

        <!-- Progress bar -->
        <ProgressBar Grid.Row="6"
                     x:Name="DownloadProgress"
                     Height="20"
                     Minimum="0"
                     Maximum="100"
                     Value="0" />

        <!-- Cancel button -->
        <Button Grid.Row="8"
                x:Name="CancelButton"
                Content="Cancel"
                Width="100"
                HorizontalAlignment="Right"
                Click="CancelButton_Click" />
    </Grid>
</Window>
