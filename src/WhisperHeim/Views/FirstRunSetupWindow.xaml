<Window x:Class="WhisperHeim.Views.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Setting up Whisperheim"
        Width="640" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Headline -->
        <TextBlock Grid.Row="0"
                   Text="Setting up Whisperheim"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <TextBlock Grid.Row="2"
                   Text="Whisperheim needs to download a few AI models before it can transcribe."
                   FontSize="13"
                   Opacity="0.75"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Per-model rows -->
        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0">
            <ItemsControl x:Name="ModelsList" />
        </ScrollViewer>

        <!-- Persistent footnote -->
        <TextBlock Grid.Row="6"
                   Text="One-time download. About 60 s on a 100 Mbps connection. Models are stored in %APPDATA%\WhisperHeim\models and survive uninstall."
                   FontSize="11"
                   TextWrapping="Wrap"
                   Opacity="0.55"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Error / retry banner (hidden by default) -->
        <Border Grid.Row="8"
                x:Name="ErrorBanner"
                Visibility="Collapsed"
                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="ErrorText"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <Button Grid.Column="1"
                        x:Name="RetryButton"
                        Content="Retry"
                        Margin="12,0,0,0"
                        Padding="14,6"
                        Click="RetryButton_Click" />
            </Grid>
        </Border>

        <!-- Bottom buttons -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    x:Name="SkipButton"
                    Content="Skip for now"
                    Padding="14,8"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Click="SkipButton_Click" />

            <Button Grid.Column="2"
                    x:Name="ContinueButton"
                    Content="Continue"
                    Padding="22,9"
                    IsEnabled="False"
                    Click="ContinueButton_Click"
                    Cursor="Hand"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
