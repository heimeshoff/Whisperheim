<UserControl x:Class="WhisperHeim.Views.Pages.DictationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:WhisperHeim.Converters"
             SizeChanged="Page_SizeChanged">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:SingleLineTextConverter x:Key="SingleLineText" />
        <!-- Quiet Engine: Subtle body text -->
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <!-- Quiet Engine: Section label — 10px uppercase bold tracking -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- Quiet Engine: Kbd pill key cap -->
        <Style x:Key="KbdPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
        </Style>
        <Style x:Key="KbdText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid Margin="40,36,40,32" MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══════ Header Section (Branding) ═══════ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32" HorizontalAlignment="Center">
                <!-- Logo with blue border -->
                <Border Width="88" Height="88"
                        CornerRadius="18" Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        BorderThickness="3"
                        BorderBrush="#FF25abfe"
                        Background="#1025abfe">
                    <Viewbox Margin="12">
                        <Canvas Width="24" Height="24">
                            <!-- Microphone head (capsule) - Blue -->
                            <Path Fill="#FF25abfe"
                                  Data="M12,2 C9.79,2 8,3.79 8,6 L8,12 C8,14.21 9.79,16 12,16 C14.21,16 16,14.21 16,12 L16,6 C16,3.79 14.21,2 12,2 Z" />
                            <!-- Microphone stand (arc + stem + base) - Orange -->
                            <Path Fill="#FFff8b00"
                                  Data="M6,11 L6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 L18,11 L16.5,11 L16.5,12 C16.5,14.49 14.49,16.5 12,16.5 C9.51,16.5 7.5,14.49 7.5,12 L7.5,11 Z M11.25,18.5 L11.25,21 L8.5,21 L8.5,22.5 L15.5,22.5 L15.5,21 L12.75,21 L12.75,18.5 Z" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- App name + version -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="Whisperheim"
                               FontSize="40" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="v1.0"
                               FontSize="18" FontWeight="Medium"
                               Foreground="#66005FAA"
                               VerticalAlignment="Top"
                               Margin="8,8,0,0" />
                </StackPanel>

                <TextBlock Text="Transform your voice into text locally and securely. Experience near-instant transcription with zero data leakage."
                           Style="{StaticResource SubtleText}"
                           TextWrapping="Wrap"
                           MaxWidth="520"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ═══════ Audio Input Device Row ═══════ -->
            <Grid x:Name="AudioInputRow" Grid.Row="1" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="AudioInputCol" Width="*" />
                    <ColumnDefinition x:Name="AudioInputGapCol" Width="24" />
                    <ColumnDefinition x:Name="AudioInputWarningCol" Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="AudioInputStackedWarningRow" Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Microphone Selector Card -->
                <Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="AUDIO INPUT DEVICE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,16" />
                        <ComboBox x:Name="MicrophoneCombo"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="MicrophoneCombo_SelectionChanged" />

                        <!-- Raw / Clean text mode toggle -->
                        <TextBlock Text="TEXT MODE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,20,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="CleanModeRadio"
                                         Content="Clean"
                                         GroupName="DictationTextMode"
                                         Margin="0,0,16,0"
                                         Checked="TextMode_Checked"
                                         ToolTip="Strip filler words (um, uh, you know...) and normalize whitespace before typing." />
                            <RadioButton x:Name="RawModeRadio"
                                         Content="Raw"
                                         GroupName="DictationTextMode"
                                         Checked="TextMode_Checked"
                                         ToolTip="Type the raw ASR output untouched (useful for debugging or verbatim capture)." />
                        </StackPanel>
                        <TextBlock x:Name="TextModeHint"
                                   Text="Clean: removes fillers like “um”, “uh”, “you know”. Raw: types exactly what was heard."
                                   Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Device Warning Card (only shows when device missing) -->
                <Border x:Name="DeviceWarningCard" Grid.Column="2" Grid.Row="0"
                        Background="#FFFFDBC8" CornerRadius="12" Padding="24"
                        Visibility="Collapsed" MinWidth="280">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" Foreground="#FF974700" Margin="0,0,12,0"
                                       VerticalAlignment="Top" />
                        <StackPanel>
                            <TextBlock Text="Action Required"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#FF311300"
                                       Margin="0,0,0,4" />
                            <TextBlock x:Name="DeviceWarning"
                                       FontSize="13" Foreground="#DD311300"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════ Bento Grid (8-col + 4-col) ═══════ -->
            <Grid x:Name="BentoGrid" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="BentoLeftCol" Width="8*" />
                    <ColumnDefinition x:Name="BentoGapCol" Width="24" />
                    <ColumnDefinition x:Name="BentoRightCol" Width="4*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="BentoStackedRow" Height="Auto" />
                </Grid.RowDefinitions>

                <!-- LEFT: Transcription Canvas -->
                <StackPanel x:Name="TranscriptionPanel" Grid.Column="0" Grid.Row="0">
                    <!-- Transcription text area with watermark -->
                    <Grid Margin="0,0,0,12">
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.02" BlurRadius="24" ShadowDepth="4" Direction="270" />
                            </Border.Effect>
                            <TextBox x:Name="TestTextBox"
                                     MinHeight="280"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="18"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="28,24"
                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                        <!-- Watermark (visible when TextBox is empty) -->
                        <TextBlock x:Name="WatermarkText"
                                   Text="Click the text box and press Ctrl+Win to start dictation. Your transcription appears as you speak."
                                   FontSize="16" Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                   IsHitTestVisible="False"
                                   Margin="28,24,28,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top" />
                    </Grid>

                    <!-- Copy / Clear buttons below the text area -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CopyButton" FontSize="11"
                                Background="Transparent" BorderThickness="0"
                                Padding="10,6" Margin="4,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Click="CopyButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy24" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Copy" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ClearButton" FontSize="11"
                                Background="Transparent" BorderThickness="0"
                                Padding="10,6" Margin="4,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Click="ClearButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT: Sidebar Cards -->
                <StackPanel x:Name="HotkeysPanel" Grid.Column="2" Grid.Row="0">
                    <!-- Hotkeys Card -->
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="28">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF005FAA" Opacity="0.06" BlurRadius="32" ShadowDepth="8" Direction="270" />
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <ui:SymbolIcon Symbol="Keyboard24" Foreground="#FF005FAA" Margin="0,0,10,0" />
                                <TextBlock Text="HOTKEYS"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </StackPanel>

                            <!-- Shortcut: Dictation -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Dictation" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Shortcut: Template Dictation -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Alt" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Template Dictation" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Shortcut: Call Recording -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="R" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Call Recording" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Footer note -->
                            <Border Margin="0,12,0,0" Padding="0,16,0,0"
                                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                                <TextBlock Text="Global hotkeys work even when Whisperheim is minimized to the system tray."
                                           FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" LineHeight="16" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ═══════ Templates Section ═══════ -->
            <StackPanel Grid.Row="3" Margin="0,40,0,0">
                <!-- Section Header + Expand/Collapse All + Add Group button -->
                <DockPanel Margin="0,0,0,16">
                    <TextBlock Text="Templates"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left" />
                    <!-- Add Group button -->
                    <Button x:Name="AddGroupButton"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Click="AddGroupButton_Click"
                            Padding="16,10" Cursor="Hand"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF005FAA" Offset="0" />
                                            <GradientStop Color="#FF0078D4" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Add24" Foreground="White" Margin="0,0,6,0" FontSize="14" />
                                        <TextBlock Text="NEW GROUP" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Expand/Collapse All toggle -->
                    <Button x:Name="ExpandCollapseAllButton"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Click="ExpandCollapseAll_Click"
                            ToolTip="Expand/Collapse All"
                            Padding="10,10" Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                    <ui:SymbolIcon x:Name="ExpandCollapseIcon" Symbol="TextCollapse24"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="16" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>

                <TextBlock Text="Craft reusable snippets for your voice dictations. Hold Ctrl+Win+Alt and speak a template name."
                           Style="{StaticResource SubtleText}"
                           Margin="0,0,0,16" />

                <!-- Search -->
                <ui:TextBox x:Name="SearchBox"
                            PlaceholderText="Search templates..."
                            TextChanged="SearchBox_TextChanged"
                            Margin="0,0,0,16" />

                <!-- Table header -->
                <Grid Margin="16,0,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="NAME"
                               Style="{StaticResource SectionLabel}" />
                    <TextBlock Grid.Column="1" Text="DESCRIPTION"
                               Style="{StaticResource SectionLabel}" />
                </Grid>

                <!-- Grouped template list -->
                <ItemsControl x:Name="TemplateGroupList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,0"
                                        AllowDrop="True"
                                        Drop="GroupDrop_Handler"
                                        DragOver="GroupDragOver_Handler">
                                <!-- Group header row -->
                                <DockPanel PreviewMouseLeftButtonDown="GroupHeader_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="GroupHeader_PreviewMouseMove">
                                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                  Click="TemplateGroupToggle_Click"
                                                  DockPanel.Dock="Left"
                                                  HorizontalAlignment="Stretch"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand" Padding="8,6"
                                                  HorizontalContentAlignment="Stretch">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}" CornerRadius="6"
                                                        Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ChevronText}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding GroupName}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       MouseLeftButtonDown="GroupName_MouseLeftButtonDown"
                                                       Cursor="{Binding RenameCursor}" />
                                            <TextBlock Text="{Binding CountDisplay}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <!-- Add template to group button (hidden for system groups) -->
                                    <Button Click="AddTemplateToGroup_Click"
                                            ToolTip="Add template to this group"
                                            DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4" Cursor="Hand" VerticalAlignment="Center"
                                            Visibility="{Binding ShowAddButton, Converter={StaticResource BoolToVisibility}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <ui:SymbolIcon Symbol="Add24" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Button>
                                    <!-- Delete empty group button (only for custom groups) -->
                                    <Button Click="DeleteGroup_Click"
                                            ToolTip="Delete empty group"
                                            DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Visibility="{Binding ShowDeleteIcon, Converter={StaticResource BoolToVisibility}}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4" Cursor="Hand" VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <ui:SymbolIcon Symbol="Delete24" FontSize="12"
                                                       Foreground="#FFE74856" />
                                    </Button>
                                </DockPanel>
                                <!-- Templates within the group -->
                                <ItemsControl ItemsSource="{Binding Items}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="TemplateRow_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    PreviewMouseLeftButtonDown="TemplateRow_PreviewMouseLeftButtonDown"
                                                    PreviewMouseMove="TemplateRow_PreviewMouseMove">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                <Setter Property="Cursor" Value="Arrow" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Padding="16,10" CornerRadius="8"
                                                                Background="Transparent">
                                                            <ContentPresenter HorizontalAlignment="Stretch" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="NameText" Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    <TextBlock x:Name="DescText" Grid.Column="1"
                                                               Text="{Binding Text, Converter={StaticResource SingleLineText}}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </Grid>
                                            </Button>
                                            <DataTemplate.Triggers>
                                                <!-- System templates: reduced contrast -->
                                                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                    <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                    <Setter TargetName="NameText" Property="FontWeight" Value="Normal" />
                                                    <Setter TargetName="DescText" Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock x:Name="TemplateEmptyState"
                           Text="No templates yet. Click the + on a group header to create one."
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="14"
                           Margin="0,20,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
    <!-- Drawer overlay (click-away background) -->
    <Border x:Name="DrawerOverlay"
            Background="#33000000"
            Visibility="Collapsed"
            MouseLeftButtonDown="DrawerOverlay_Click" />

    <!-- Detail Drawer -->
    <Border x:Name="DrawerPanel"
            HorizontalAlignment="Right"
            Width="440"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            Visibility="Collapsed"
            RenderTransformOrigin="1,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="DrawerTranslate" X="440" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" Opacity="0.15" BlurRadius="40" ShadowDepth="-4" Direction="180" />
        </Border.Effect>
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Drawer header with close button -->
            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <Button x:Name="DrawerCloseButton"
                        DockPanel.Dock="Right"
                        Click="DrawerClose_Click"
                        VerticalAlignment="Top"
                        Padding="6"
                        Cursor="Hand"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTip="Close">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="IconBd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="IconBd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock x:Name="DrawerTitle"
                           Text="Edit Template"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Drawer body -->
            <StackPanel Grid.Row="1">
                <!-- Template Name -->
                <TextBlock Text="TEMPLATE NAME"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,8" />
                <ui:TextBox x:Name="NameTextBox"
                            PlaceholderText="Template trigger name (e.g. 'greeting')"
                            Margin="0,0,0,24" />

                <!-- Template Body -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="TEMPLATE BODY"
                               Style="{StaticResource SectionLabel}"
                               DockPanel.Dock="Left" VerticalAlignment="Center" />
                    <!-- Placeholder tag pills -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="{}{date}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="{}{time}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                    </StackPanel>
                </DockPanel>
                <ui:TextBox x:Name="TextTextBox"
                            AcceptsReturn="True"
                            MinHeight="200"
                            MaxHeight="360"
                            PlaceholderText="Template text. Use {date}, {time} for placeholders."
                            Margin="0,0,0,32" />
            </StackPanel>

            <!-- Action Footer -->
            <Border Grid.Row="2"
                    Padding="0,20,0,0"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <!-- Delete button on the left -->
                    <Button x:Name="DrawerDeleteButton"
                            DockPanel.Dock="Left"
                            Click="DrawerDelete_Click"
                            Padding="10,8" Cursor="Hand"
                            BorderThickness="0"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                        Background="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Delete24" Foreground="#FFE74856" Margin="0,0,6,0" FontSize="14" />
                                        <TextBlock Text="DELETE" FontSize="10" FontWeight="Bold"
                                                   Foreground="#FFE74856" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#19E74856" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Save button on the right -->
                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Right"
                                HorizontalAlignment="Right">
                        <Button x:Name="SaveButton"
                                Click="SaveButton_Click"
                                Foreground="White" FontWeight="SemiBold"
                                Padding="24,10" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF005FAA" Offset="0" />
                                                <GradientStop Color="#FF0078D4" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="16" ShadowDepth="4" Direction="270" />
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="SaveButtonText" Text="Save Template" Foreground="White" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
    </Grid>
</UserControl>
