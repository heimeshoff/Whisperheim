<UserControl x:Class="WhisperHeim.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource ApplicationBackgroundBrush}">
        <StackPanel Margin="40,36,40,32" MaxWidth="900"
                    HorizontalAlignment="Center">

            <!-- ======= Hero Section ======= -->
            <StackPanel HorizontalAlignment="Center" Margin="0,20,0,48">
                <!-- Logo with blue border -->
                <Border Width="88" Height="88"
                        CornerRadius="18" Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        BorderThickness="3"
                        BorderBrush="#FF25abfe"
                        Background="#1025abfe">
                    <Viewbox Margin="12">
                        <Canvas Width="24" Height="24">
                            <!-- Microphone head (capsule) - Blue -->
                            <Path Fill="#FF25abfe"
                                  Data="M12,2 C9.79,2 8,3.79 8,6 L8,12 C8,14.21 9.79,16 12,16 C14.21,16 16,14.21 16,12 L16,6 C16,3.79 14.21,2 12,2 Z" />
                            <!-- Microphone stand (arc + stem + base) - Orange -->
                            <Path Fill="#FFff8b00"
                                  Data="M6,11 L6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 L18,11 L16.5,11 L16.5,12 C16.5,14.49 14.49,16.5 12,16.5 C9.51,16.5 7.5,14.49 7.5,12 L7.5,11 Z M11.25,18.5 L11.25,21 L8.5,21 L8.5,22.5 L15.5,22.5 L15.5,21 L12.75,21 L12.75,18.5 Z" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- App name + version -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="Whisperheim"
                               FontSize="40" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="v1.0"
                               FontSize="18" FontWeight="Medium"
                               Foreground="#66005FAA"
                               VerticalAlignment="Top"
                               Margin="8,8,0,0" />
                </StackPanel>

                <TextBlock Text="Transform your voice into text locally and securely. Experience near-instant transcription with zero data leakage."
                           FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="460" />
            </StackPanel>

            <!-- ======= Profile & Contact Card ======= -->
            <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="12" Padding="28" Margin="0,0,0,32">
                <StackPanel>
                    <!-- Profile Section -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Profile Image -->
                        <Border Grid.Column="0" Width="140" Height="140"
                                CornerRadius="70" Margin="0,0,24,0"
                                VerticalAlignment="Top"
                                BorderThickness="3" BorderBrush="#FF25abfe">
                            <Border.Background>
                                <ImageBrush ImageSource="/Assets/heimeshoff.jpg"
                                            Stretch="UniformToFill" />
                            </Border.Background>
                            <Border CornerRadius="70" />
                        </Border>

                        <!-- Bio Text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="16" TextWrapping="Wrap" LineHeight="24"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,0,12">
                                <Run Text="Hi, I'm " />
                                <Run Text="Marco Heimeshoff" FontWeight="Bold" Foreground="#FF25abfe" />
                                <Run Text=" - trainer, consultant, and conference organiser focused on " />
                                <Run Text="Domain-Driven Design" FontWeight="Bold" Foreground="#FF25abfe" />
                                <Run Text=" and " />
                                <Run Text="collaborative modeling" FontWeight="Bold" Foreground="#FF25abfe" />
                                <Run Text="." />
                            </TextBlock>

                            <TextBlock FontSize="13" TextWrapping="Wrap" LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,8">
                                <Run Text="DDD is all about creating a " /><Run Text="ubiquitous language" FontStyle="Italic" /><Run Text=" within " /><Run Text="bounded contexts" FontStyle="Italic" /><Run Text=" &#x2014; and with " /><Run Text="Whisperheim" FontStyle="Italic" /><Run Text=", I figured it's time to let your own language flow directly into words on screen." />
                            </TextBlock>

                            <TextBlock Text="When I'm not helping teams design meaningful software, I enjoy building open-source tools like this one to make life a little smoother."
                                       FontSize="13" TextWrapping="Wrap" LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Margin="0,0,0,24"
                            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                    <!-- Contact Section -->
                    <TextBlock Text="Get in Touch"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock Margin="0,0,0,16" FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text="If you'd like to " /><Run Text="learn more about my trainings or consulting work" FontWeight="Bold" /><Run Text=", feel free to reach out:" />
                    </TextBlock>

                    <StackPanel Margin="0,0,0,0">
                        <!-- Website -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Globe24" FontSize="20" Margin="0,0,12,0"
                                           Foreground="#FF25abfe" VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink x:Name="LinkWebsite" RequestNavigate="Hyperlink_RequestNavigate"
                                           NavigateUri="https://heimeshoff.de"
                                           Foreground="#FF25abfe" TextDecorations="None">
                                    <Run Text="heimeshoff.de" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Bluesky -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#1185fe"
                                          Data="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink x:Name="LinkBluesky" RequestNavigate="Hyperlink_RequestNavigate"
                                           NavigateUri="https://bsky.app/profile/heimeshoff.de"
                                           Foreground="#FF25abfe" TextDecorations="None">
                                    <Run Text="@Heimeshoff.de" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- LinkedIn -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#0A66C2"
                                          Data="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink x:Name="LinkLinkedIn" RequestNavigate="Hyperlink_RequestNavigate"
                                           NavigateUri="https://linkedin.com/in/heimeshoff"
                                           Foreground="#FF25abfe" TextDecorations="None">
                                    <Run Text="linkedin.com/in/heimeshoff" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ======= Support & GitHub Card ======= -->
            <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="12" Padding="28" Margin="0,0,0,32">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="If you enjoy Whisperheim and want to support my open-source work, you can buy me a coffee!"
                               FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />

                    <!-- Ko-fi Button -->
                    <Button x:Name="KofiButton" Click="KofiButton_Click"
                            HorizontalAlignment="Center" Cursor="Hand"
                            Margin="0,0,0,16" Padding="24,12">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="KofiBd" CornerRadius="10"
                                                    Padding="{TemplateBinding Padding}"
                                                    Cursor="Hand">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#FF25abfe" Offset="0" />
                                                        <GradientStop Color="#FF005FAA" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="KofiBd" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Buy me a coffee on Ko-fi"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16">
                        <Run Text="Otherwise, just " /><Run Text="enjoy using Whisperheim for free" FontWeight="Bold" /><Run Text=" &#x2014; and thanks for giving it a try!" />
                    </TextBlock>

                    <!-- GitHub Link -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Star24" FontSize="18" Margin="0,0,8,0"
                                       Foreground="#FF25abfe" VerticalAlignment="Center" />
                        <TextBlock VerticalAlignment="Center">
                            <Hyperlink x:Name="LinkGitHub" RequestNavigate="Hyperlink_RequestNavigate"
                                       NavigateUri="https://github.com/heimeshoff/WhisperHeim"
                                       Foreground="#FF25abfe" TextDecorations="None">
                                <Run Text="View on GitHub" FontWeight="Medium" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ======= Bento Grid: Philosophy + Models ======= -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Philosophy card -->
                <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="28">
                    <StackPanel>
                        <TextBlock Text="PHILOSOPHY"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="Ethereal Precision."
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="Whisperheim was designed to bridge the gap between technical utility and digital sanctuary. No data leaves your machine, ensuring absolute privacy without sacrificing performance."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="19"
                                   Margin="0,0,0,24" />
                        <TextBlock Text="ARCHITECTURE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Real Core + GPU"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,16,0" />
                            <ui:SymbolIcon Symbol="Flash24" Foreground="#FF005FAA" FontSize="18" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- RIGHT: AI Models card -->
                <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="0">
                    <StackPanel>
                        <DockPanel Margin="24,24,24,16">
                            <TextBlock Text="AI MODELS"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                            <Border Background="#FFD3E3FF" CornerRadius="8" Padding="10,4"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock Text="STATUS" FontSize="9" FontWeight="Bold"
                                           Foreground="#FF004883" />
                            </Border>
                        </DockPanel>

                        <!-- Bundled models attribution (Task 109) -->
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="10"
                                Padding="14,10"
                                Margin="12,0,12,4">
                            <StackPanel>
                                <TextBlock Text="BUNDLED WITH WHISPERHEIM"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4" />
                                <TextBlock FontSize="11" TextWrapping="Wrap" LineHeight="16"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="Silero VAD" FontWeight="SemiBold" /><Run Text=" (MIT License) by Silero Team. " /><Run Text="Pyannote Segmentation 3.0" FontWeight="SemiBold" /><Run Text=" int8 conversion by csukuangfj (MIT License), based on pyannote.audio (MIT)." />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Model list -->
                        <ItemsControl x:Name="ModelList" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="10"
                                            Padding="16,14"
                                            Margin="0,3,0,3"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ModelCard_Click"
                                            Tag="{Binding ProjectUrl}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <Border Grid.Column="0"
                                                    Width="36" Height="36"
                                                    CornerRadius="8"
                                                    Margin="0,0,14,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#19005FAA" />
                                                </Border.Background>
                                                <ui:SymbolIcon Symbol="Checkmark24"
                                                               Foreground="{Binding StatusBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name and description -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    <ui:SymbolIcon Symbol="Open24"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   Margin="6,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Size and status -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="6" Padding="10,4"
                                                        HorizontalAlignment="Right" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </Border>
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           Foreground="{Binding StatusBrush}"
                                                           FontWeight="Medium"
                                                           HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
