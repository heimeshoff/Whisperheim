<Window x:Class="WhisperHeim.Views.FfmpegMissingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="FFmpeg required"
        Width="640" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Headline -->
        <TextBlock Grid.Row="0"
                   Text="FFmpeg is not installed"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <!-- Reason / explainer -->
        <StackPanel Grid.Row="2">
            <TextBlock x:Name="ReasonText"
                       FontSize="13"
                       Opacity="0.85"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock FontSize="12"
                       Opacity="0.65"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Whisperheim uses FFmpeg to transcribe YouTube videos, web streams, and certain audio formats. It's a separate program — install it once and Whisperheim will find it automatically." />
        </StackPanel>

        <!-- Action buttons row -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    x:Name="WingetButton"
                    Click="WingetButton_Click"
                    Padding="16,11"
                    Cursor="Hand"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="13"
                    FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,8,0" />
                    <TextBlock Text="Install with Windows Package Manager" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    x:Name="DownloadPageButton"
                    Content="Open download page"
                    Padding="14,10"
                    Click="DownloadPageButton_Click"
                    Cursor="Hand"
                    FontSize="12" />

            <Button Grid.Column="4"
                    x:Name="RedetectButton"
                    Content="I already installed it"
                    Padding="14,10"
                    Click="RedetectButton_Click"
                    Cursor="Hand"
                    FontSize="12" />
        </Grid>

        <!-- Inline status / error banner -->
        <Border Grid.Row="6"
                x:Name="StatusBanner"
                Visibility="Collapsed"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10"
                VerticalAlignment="Top">
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </Border>

        <!-- Install log textbox (visible while winget runs) -->
        <Border Grid.Row="6"
                x:Name="LogContainer"
                Visibility="Collapsed"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,10,14,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="LogHeader"
                               Text="Running winget install Gyan.FFmpeg..."
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.85"
                               VerticalAlignment="Center" />
                    <ui:ProgressRing Grid.Column="1"
                                     x:Name="InstallSpinner"
                                     IsIndeterminate="True"
                                     Width="18" Height="18" />
                </Grid>

                <TextBox Grid.Row="1"
                         x:Name="LogTextBox"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         FontSize="11"
                         Padding="14,4,14,12"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </Grid>
        </Border>

        <!-- Detection success card -->
        <Border Grid.Row="8"
                x:Name="DetectedCard"
                Visibility="Collapsed"
                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="CheckmarkCircle24" Margin="0,0,8,0" />
                <TextBlock x:Name="DetectedText"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Bottom buttons -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    x:Name="CancelButton"
                    Content="Cancel"
                    Padding="20,9"
                    Click="CancelButton_Click"
                    Cursor="Hand"
                    FontSize="12" />
        </Grid>
    </Grid>
</Window>
