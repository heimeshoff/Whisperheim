<Window x:Class="WhisperHeim.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Whisperheim Toast"
        SizeToContent="Width"
        Height="Auto"
        MinWidth="200"
        MaxWidth="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Opacity="0">

    <Border x:Name="ToastBorder"
            Background="#EE2D2D2D"
            CornerRadius="8"
            Padding="16,10"
            Margin="8"
            BorderThickness="1"
            BorderBrush="#55FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.4" ShadowDepth="2" />
        </Border.Effect>
        <TextBlock x:Name="ToastText"
                   Foreground="#DDFFFFFF"
                   FontSize="14"
                   FontFamily="Segoe UI"
                   TextWrapping="Wrap"
                   MaxWidth="460"
                   Text="Toast message" />
    </Border>
</Window>
