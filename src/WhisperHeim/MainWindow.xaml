<ui:FluentWindow x:Class="WhisperHeim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:WhisperHeim.Views.Controls"
        Title="Whisperheim"
        Height="800" Width="1200"
        WindowStartupLocation="Manual"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <!-- Quiet Engine: Pill-shaped nav item style -->
        <Style x:Key="NavPillItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF005FAA" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="Whisperheim" />

        <!-- Tray icon now lives in App-owned TrayIconHost (see Services/Tray/TrayIconHost.cs)
             so it can register before any window is shown on start-minimized launches. -->

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Nav panel -->
            <Grid x:Name="NavPanel" Grid.Column="0" Margin="12,0,4,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Branding header -->
                <StackPanel x:Name="BrandingHeader" Grid.Row="0" Margin="16,12,16,24"
                            Cursor="Hand"
                            MouseLeftButtonDown="BrandingHeader_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <!-- Logo icon (no background box, just the two-tone mic) -->
                        <Viewbox x:Name="BrandingLogo" Width="28" Height="28"
                                 Margin="0,0,10,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- Microphone head (capsule) - Blue -->
                                <Path Fill="#FF25abfe"
                                      Data="M12,2 C9.79,2 8,3.79 8,6 L8,12 C8,14.21 9.79,16 12,16 C14.21,16 16,14.21 16,12 L16,6 C16,3.79 14.21,2 12,2 Z" />
                                <!-- Microphone stand (arc + stem + base) - Orange -->
                                <Path Fill="#FFff8b00"
                                      Data="M6,11 L6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 L18,11 L16.5,11 L16.5,12 C16.5,14.49 14.49,16.5 12,16.5 C9.51,16.5 7.5,14.49 7.5,12 L7.5,11 Z M11.25,18.5 L11.25,21 L8.5,21 L8.5,22.5 L15.5,22.5 L15.5,21 L12.75,21 L12.75,18.5 Z" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="BrandingTitle" Text="Whisperheim"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation items -->
                <ListBox x:Name="NavList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Tag="Dictation" IsSelected="True" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Mic24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelDictation" Text="DICTATION" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
<ListBoxItem Tag="Recordings" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ChatMultiple24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelRecordings" Text="CONVERSATIONS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Streams" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Video24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelStreams" Text="STREAMS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Settings" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelSettings" Text="SETTINGS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- About nav item pinned to bottom -->
                <ListBox x:Name="NavBottomList"
                         Grid.Row="2"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,8,0,0"
                         SelectionChanged="NavBottomList_SelectionChanged">
                    <ListBoxItem Tag="About" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelAbout" Text="ABOUT" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Grid>

            <!-- Page content area -->
            <ContentPresenter x:Name="PageContent"
                              Grid.Column="1" />
        </Grid>

        <!-- Transcription queue bottom bar (visible across all pages) -->
        <controls:TranscriptionBottomBar x:Name="TranscriptionBar"
                                          Grid.Row="2"
                                          Visibility="Collapsed" />

        <!-- STT API status footer (always visible): the loopback endpoint Claude /
             local tooling calls, plus a health dot (green = listening & idle,
             amber = busy, grey = offline). See ADR-0001 / task main-q4m8t. -->
        <Border x:Name="SttStatusFooter"
                Grid.Row="3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Padding="14,5"
                ToolTip="WhisperHeim's local speech-to-text API. Point Claude or other local tools at this endpoint (POST /transcribe). Override with the WHISPERHEIM_ENDPOINT env var.">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="SttHealthDot"
                         Width="9" Height="9"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center" />
                <TextBlock Text="STT API"
                           FontSize="12" FontWeight="Medium"
                           VerticalAlignment="Center"
                           Opacity="0.85"
                           Margin="0,0,8,0" />
                <TextBlock x:Name="SttEndpointText"
                           FontSize="12" FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Opacity="0.85" />
                <TextBlock x:Name="SttStateText"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Opacity="0.55"
                           Margin="8,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
